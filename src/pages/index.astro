---
import Layout from '../layouts/Layout.astro';
import raw from '../content/modlist.md?raw';

interface Table {
  headers: string[];
  rows: string[][];
}

interface Section {
  title: string;
  body: string;
  hasCheckboxes: boolean;
  defaultCollapsed: boolean;
  table: Table;
}

// Convert markdown inline links to <a> tags for set:html rendering
const convertLinks = (s: string) =>
  s.replace(
    /\[([^\]]+)\]\(([^)]+)\)/g,
    '<a href="$2" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-dotted decoration-base-content/30 hover:decoration-base-content/70 transition-colors">$1</a>'
  );

// Strip all markup to plain text — used for stable localStorage keys
const toPlainText = (s: string) =>
  s.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // markdown links → text
   .replace(/<[^>]+>/g, '')                  // html tags
   .replace(/\s+/g, ' ')
   .trim();

function parseTableLines(lines: string[]): Table {
  if (lines.length < 3) return { headers: [], rows: [] };
  const split = (line: string) => line.split('|').slice(1, -1).map(c => c.trim());
  return {
    headers: split(lines[0]).map(h => h.replace(/\*\*/g, '')),
    rows: lines.slice(2).map(line => split(line).map(convertLinks)),
  };
}

function escHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function fmtInline(s: string): string {
  return escHtml(s)
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g,
      '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');
}

function mdToHtml(md: string): string {
  const lines = md.split('\n');
  const out: string[] = [];
  let inCode = false;
  let codeLines: string[] = [];
  let inList = false;

  const closeList = () => {
    if (inList) { out.push('</ul>'); inList = false; }
  };

  for (const line of lines) {
    if (line.trim() === '```') {
      if (inCode) {
        closeList();
        out.push(
          `<div class="not-prose relative my-4">` +
          `<pre class="overflow-x-auto rounded-lg bg-base-300 px-4 py-4 pr-20 text-xs font-mono leading-relaxed whitespace-pre-wrap break-all"><code>${escHtml(codeLines.join('\n'))}</code></pre>` +
          `<button class="copy-btn absolute right-2 top-2 btn btn-xs btn-ghost opacity-50 hover:opacity-100 transition-opacity">copy</button>` +
          `</div>`
        );
        codeLines = [];
        inCode = false;
      } else {
        closeList();
        inCode = true;
      }
      continue;
    }

    if (inCode) { codeLines.push(line); continue; }

    if (!line.trim()) { closeList(); continue; }

    if (line.startsWith('### ')) {
      closeList();
      out.push(`<h3>${fmtInline(line.slice(4))}</h3>`);
      continue;
    }

    if (line.match(/^[-*] /)) {
      if (!inList) { out.push('<ul>'); inList = true; }
      out.push(`<li>${fmtInline(line.slice(2))}</li>`);
      continue;
    }

    closeList();
    out.push(`<p>${fmtInline(line)}</p>`);
  }

  closeList();
  return out.join('\n');
}

function parseMarkdown(markdown: string): { pageTitle: string; serverIP: string | null; sections: Section[] } {
  const titleMatch = markdown.match(/^#\s+(.+)$/m);
  const pageTitle = titleMatch ? titleMatch[1].trim() : '';

  // Extract IP from content before first ## section
  const firstSection = markdown.indexOf('\n## ');
  const introPart = firstSection >= 0 ? markdown.slice(0, firstSection) : '';
  const ipMatch = introPart.match(/IP[^:]*:\s*`([^`]+)`/);
  const serverIP = ipMatch ? ipMatch[1] : null;

  const sectionChunks = markdown.split(/^(?=## )/m).filter(c => c.startsWith('## '));

  const sections: Section[] = sectionChunks.map(chunk => {
    const lines = chunk.split('\n');
    const headingLine = lines[0];
    const hasCheckboxes = /<!--\s*checklist\s*-->/.test(headingLine);
    const defaultCollapsed = /\(click to expand\)/i.test(headingLine);
    const title = headingLine.replace(/^##\s+/, '').replace(/<!--.*-->/, '').trim();

    const bodyLines: string[] = [];
    const tableLines: string[] = [];

    for (const line of lines.slice(1)) {
      if (line.trim().startsWith('|')) {
        tableLines.push(line);
      } else {
        bodyLines.push(line);
      }
    }

    return {
      title,
      body: bodyLines.join('\n').trim(),
      hasCheckboxes,
      defaultCollapsed,
      table: parseTableLines(tableLines),
    };
  });

  return { pageTitle, serverIP, sections };
}

const { pageTitle, serverIP, sections } = parseMarkdown(raw);
---

<Layout title={pageTitle}>
  <main class="min-h-screen bg-base-200 text-base-content">
    <div class="container mx-auto px-4 py-8 max-w-6xl">

      <header class="mb-6">
        <h1 class="text-2xl font-bold tracking-tight">{pageTitle}</h1>
      </header>

      {serverIP && (
        <div class="mb-8 flex items-center gap-4 rounded-xl border border-base-content/10 bg-base-100 px-6 py-4">
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium uppercase tracking-wider text-base-content/40 mb-0.5">Server IP</p>
            <p class="font-mono font-semibold text-base">{serverIP}</p>
          </div>
          <button id="copy-ip-btn" class="btn btn-sm btn-ghost shrink-0" data-ip={serverIP}>copy</button>
        </div>
      )}

      {sections.map((section, si) => {
        const isGuide = section.table.headers.length === 0 && section.body.trim().length > 0;

        if (isGuide) {
          return (
            <section class="mb-8">
              <div class="rounded-xl border border-base-content/10 bg-base-100">
                <button class={`section-toggle w-full px-4 py-3 flex items-center justify-between gap-2 hover:bg-base-200/50 transition-colors rounded-t-xl ${section.defaultCollapsed ? 'rounded-b-xl' : 'border-b border-base-content/10'}`} data-default-collapsed={section.defaultCollapsed ? 'true' : undefined}>
                  <h2 class="text-sm font-semibold text-base-content/70">{section.title}</h2>
                  <svg class="chevron w-3.5 h-3.5 text-base-content/40 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class={`card-body${section.defaultCollapsed ? ' collapsed' : ''}`}>
                  <div>
                    <div class="prose prose-sm prose-invert max-w-none">
                      <div set:html={mdToHtml(section.body)} />
                    </div>
                  </div>
                </div>
              </div>
            </section>
          );
        }

        return (
          <section class="mb-8">
            <div class="rounded-xl border border-base-content/10 bg-base-100 overflow-hidden">
              <button class="section-toggle w-full px-4 py-3 border-b border-base-content/10 flex items-center gap-2 hover:bg-base-200/50 transition-colors rounded-t-xl">
                <h2 class="text-sm font-semibold text-base-content/70 flex-1 text-left">{section.title}</h2>
                <span class="badge badge-sm badge-ghost font-normal opacity-60">{section.table.rows.length}</span>
                <svg class="chevron w-3.5 h-3.5 text-base-content/40 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="card-body">
                <div>
                  <div class="overflow-x-auto">
              <table class="table table-sm" id={`table-${si}`}>
                <thead>
                  <tr>
                    {section.hasCheckboxes && <th class="w-6"></th>}
                    {section.table.headers.map((h) => (
                      <th
                        class="cursor-pointer select-none hover:bg-base-200 transition-colors text-xs font-medium tracking-wide uppercase text-base-content/50"
                        data-sort=""
                      >
                        {h}&nbsp;<span class="sort-icon opacity-40">⇅</span>
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {section.table.rows.map(row => (
                    <tr class="hover" data-mod={section.hasCheckboxes ? toPlainText(row[1]) : undefined}>
                      {section.hasCheckboxes && (
                        <td>
                          <input type="checkbox" class="checkbox checkbox-xs mod-check" />
                        </td>
                      )}
                      {row.map((cell, i) => {
                        if (i === 0)
                          return <td class="whitespace-nowrap"><span class="badge badge-sm badge-ghost">{toPlainText(cell)}</span></td>;
                        if (i === row.length - 1)
                          return <td class="whitespace-nowrap text-base-content/50 text-xs">{toPlainText(cell) || '—'}</td>;
                        return <td set:html={cell} />;
                      })}
                    </tr>
                  ))}
                </tbody>
              </table>
                </div>
                </div>
              </div>
            </div>
          </section>
        );
      })}

    </div>
  </main>

  <script>
    // Initialize sections that are collapsed by default
    document.querySelectorAll<HTMLButtonElement>('.section-toggle[data-default-collapsed]').forEach(btn => {
      const chevron = btn.querySelector('.chevron') as HTMLElement;
      if (chevron) chevron.style.transform = 'rotate(-90deg)';
    });

    // Collapsible sections
    document.querySelectorAll<HTMLButtonElement>('.section-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const body = btn.nextElementSibling as HTMLElement;
        const chevron = btn.querySelector('.chevron') as HTMLElement;
        const collapsed = body.classList.toggle('collapsed');
        chevron.style.transform = collapsed ? 'rotate(-90deg)' : '';
        // hide border-b when collapsed so card looks fully closed
        btn.classList.toggle('border-b', !collapsed);
        btn.classList.toggle('rounded-b-xl', collapsed);
      });
    });

    // Copy IP button
    document.getElementById('copy-ip-btn')?.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const ip = btn.dataset.ip ?? '';
      navigator.clipboard.writeText(ip).then(() => {
        btn.textContent = 'copied!';
        setTimeout(() => { btn.textContent = 'copy'; }, 2000);
      });
    });

    // Copy code block buttons (reads textContent from the adjacent <code> element)
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const code = btn.closest('div')?.querySelector('code');
        const text = code?.textContent ?? '';
        navigator.clipboard.writeText(text).then(() => {
          const orig = btn.textContent;
          btn.textContent = 'copied!';
          setTimeout(() => { btn.textContent = orig ?? 'copy'; }, 2000);
        });
      });
    });

    // Sort — uses th.cellIndex so the checkbox column doesn't offset data indices
    document.querySelectorAll<HTMLTableElement>('table[id]').forEach(table => {
      const ths = table.querySelectorAll<HTMLElement>('th[data-sort]');
      ths.forEach(th => {
        th.addEventListener('click', () => {
          const col = th.cellIndex;
          const asc = th.dataset.sort !== 'asc';

          ths.forEach(h => {
            h.dataset.sort = '';
            const icon = h.querySelector('.sort-icon');
            if (icon) icon.textContent = '⇅';
          });

          th.dataset.sort = asc ? 'asc' : 'desc';
          const icon = th.querySelector('.sort-icon');
          if (icon) icon.textContent = asc ? '↑' : '↓';

          const tbody = table.querySelector('tbody')!;
          const rows = Array.from(tbody.querySelectorAll('tr'));
          rows.sort((a, b) => {
            const aText = (a.cells[col]?.textContent ?? '').trim().toLowerCase();
            const bText = (b.cells[col]?.textContent ?? '').trim().toLowerCase();
            return asc ? aText.localeCompare(bText) : bText.localeCompare(aText);
          });
          rows.forEach(row => tbody.appendChild(row));
        });
      });
    });

    // Checkbox persistence via localStorage
    const STORAGE_KEY = 'modlist-checked';

    const loadChecked = (): Set<string> => {
      try { return new Set(JSON.parse(localStorage.getItem(STORAGE_KEY) ?? '[]')); }
      catch { return new Set(); }
    };

    const saveChecked = (set: Set<string>): void => {
      localStorage.setItem(STORAGE_KEY, JSON.stringify([...set]));
    };

    const checked = loadChecked();

    document.querySelectorAll<HTMLInputElement>('.mod-check').forEach(cb => {
      const row = cb.closest('tr') as HTMLTableRowElement | null;
      const name = row?.dataset.mod ?? '';
      if (!name || !row) return;

      if (checked.has(name)) {
        cb.checked = true;
        row.classList.add('opacity-40');
      }

      cb.addEventListener('change', () => {
        const set = loadChecked();
        if (cb.checked) {
          set.add(name);
          row.classList.add('opacity-40');
        } else {
          set.delete(name);
          row.classList.remove('opacity-40');
        }
        saveChecked(set);
      });
    });
  </script>
</Layout>
